// SMX Drives - Production Traceability & Workforce Performance
// PostgreSQL schema - permanent logs, 5+ year retention

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----- Auth & Users -----
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash String   @map("password_hash")
  name          String
  role          Role     @default(PRODUCTION_EMPLOYEE)
  active        Boolean  @default(true)
  faceDescriptor String?  @map("face_descriptor") // JSON float32 array [128 numbers]
  faceEnrolled  Boolean  @default(false) @map("face_enrolled")
  stagePermissions String? @map("stage_permissions") // JSON array of stage IDs user can work on
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  assignedStages       StageAssignment[]
  stageLogs            StageLog[]
  qcRecords            QCRecord[]
  reworkRecords        ReworkRecord[]
  timelineLogs         TimelineLog[]
  approvedBy           StageLog[]             @relation("ApprovedBy")
  performance          UserPerformanceSummary[]
  auditLogs            AuditLog[]
  componentChecks      ComponentCheck[]
  workSubmissions      StageWorkSubmission[]  @relation("WorkSubmissions")
  createdProformas     ProformaInvoice[]      @relation("PICreatedBy")
  approvedProformas    ProformaInvoice[]      @relation("PIApprovedBy")
  appSettings          AppSetting[]
  dispatches           Dispatch[]             @relation("DispatchedBy")
  approvedDispatches   Dispatch[]             @relation("DispatchApprovedBy")
  dispatchItemsScanned DispatchItem[]         @relation("DispatchItemScannedBy")
  dispatchOrders       DispatchOrder[]        @relation("DOCreatedBy")
  approvedDOs          DispatchOrder[]        @relation("DOApprovedBy")
  boxItemsScanned      PackingBoxItem[]       @relation("BoxItemScannedBy")
  doScansScanned       DispatchOrderScan[]    @relation("DOScanScannedBy")
  // New relations
  invoicesApproved     Invoice[]              @relation("InvoiceApprovedBy")
  payments             Payment[]
  attendanceRecords    AttendanceRecord[]
  stockMovements       StockMovement[]
  purchaseRequests     PurchaseRequest[]
  purchaseOrders       PurchaseOrder[]
  goodsReceipts        GoodsReceipt[]
  returnRequestsReported   ReturnRequest[]    @relation("ReturnReportedBy")
  returnRequestsEvaluated  ReturnRequest[]    @relation("ReturnEvaluatedBy")
  repairLogs           RepairLog[]
  reworkMaterialsRequested ReworkMaterial[] @relation("ReworkMaterialRequestedBy")
  reworkMaterialsIssued    ReworkMaterial[] @relation("ReworkMaterialIssuedBy")
  notifications        Notification[]
  orderNotes           OrderNote[]            @relation("OrderNoteAuthor")
  jobCardsCreated      JobCard[]              @relation("JCCreatedBy")
  jobCardsDispatched   JobCard[]              @relation("JCDispatchedBy")
  // Procurement (new flow)
  requirementOrdersApproved RequirementOrder[] @relation("ROApprovedBy")
  rfqsCreated          RFQ[]                  @relation("RFQCreatedBy")
  posApproved          PurchaseOrder[]        @relation("POApprovedBy")
  goodsArrivals        GoodsArrivalNote[]     @relation("GANCreatedBy")
  vendorPerformance    VendorPerformance[]
  poOverrideRequests   POOverrideRequest[]
  damageReports        DamageReport[]
  paymentRequestsRaised    PaymentRequest[] @relation("PaymentRequestedBy")
  paymentRequestsAccounts  PaymentRequest[] @relation("PaymentAccountsBy")
  paymentRequestsAdmin     PaymentRequest[] @relation("PaymentAdminApproved")
  paymentsProcessed        PaymentRequest[] @relation("PaymentProcessedBy")
  vendorPaymentsProcessed  VendorPayment[]  @relation("VendorPaymentProcessedBy")
  priceBreakdownFactors    PriceBreakdownFactor[]
  samplesRequested         SampleRequest[]  @relation("SampleRequestedBy")
  samplesApproved          SampleRequest[]  @relation("SampleApprovedBy")
  implementationGoodsCreated ImplementationGood[] @relation("IGCreatedBy")
  igGanActions               ImplementationGood[] @relation("IGGanBy")
  igGrnActions               ImplementationGood[] @relation("IGGrnBy")
  igTimelineEntries          IGTimeline[]         @relation("IGTimelineUser")
  returnFaultApprovals       ReturnRequest[]      @relation("ReturnFaultApprovedBy")
  returnBlameRecords         ReturnRequest[]      @relation("ReturnBlameEmployee")
  harnessUnitsAssigned       HarnessUnit[]        @relation("HarnessAssignedTo")
}

enum Role {
  ADMIN
  PRODUCTION_MANAGER
  PRODUCTION_EMPLOYEE
  QC_USER            // dedicated QC & software testing role
  SALES
  ACCOUNTS
  SHIPPING           // deprecated — use ACCOUNTS for shipping approval
  PURCHASE_MANAGER   // procurement: purchase requests, vendors, bids, POs
  INVENTORY_MANAGER  // inventory: raw materials, BOM, stock, GRN, adjustments
  PACKING            // packing team — scans/packs/seals dispatch orders
  STORE_MANAGER      // legacy alias for INVENTORY_MANAGER
  HARNESS_PRODUCTION // harness manufacturing, crimping, QC
}

// ----- Products / Models -----
model Product {
  id          String   @id @default(cuid())
  code        String   @unique  // e.g. 1000 for SMX1000
  name        String
  description String?
  productType String   @default("MANUFACTURED") @map("product_type") // MANUFACTURED | TRADING
  hsnCode     String?  @map("hsn_code") // e.g. 85371000 (controllers), 85011090 (motors)
  colors      String[] @default([])    // available colors e.g. ["Black", "Silver", "White"]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  orders          Order[]
  units           ControllerUnit[]
  components      ProductComponent[]
  checklistItems  StageChecklistItem[]
  proformaItems   ProformaInvoiceItem[]
  bomItems        BOMItem[]
  sampleRequests  SampleRequest[]
  qcTestItems     QCTestItem[]
  harnessOrders      Order[]            @relation("HarnessProduct")
  harnessUnits       HarnessUnit[]
  harnessConnectors  HarnessConnector[]
}

// ----- Product Components (BOM per model) -----
model ProductComponent {
  id          String     @id @default(cuid())
  productId   String     @map("product_id")
  name        String
  partNumber  String?    @map("part_number")
  barcode     String?
  description String?
  stage       StageType?
  sortOrder   Int        @default(0) @map("sort_order")
  required    Boolean    @default(true)
  active      Boolean    @default(true)
  printed     Boolean    @default(false)
  printedAt   DateTime?  @map("printed_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  product Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  checks  ComponentCheck[]
  @@map("product_components")
}

model ComponentCheck {
  id           String    @id @default(cuid())
  unitId       String    @map("unit_id")
  componentId  String    @map("component_id")
  stage        StageType
  checked      Boolean   @default(false)
  scannedValue String?   @map("scanned_value")
  checkedById  String?   @map("checked_by_id")
  checkedAt    DateTime? @map("checked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  unit      ControllerUnit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  component ProductComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  checker   User?            @relation(fields: [checkedById], references: [id])
  @@unique([unitId, componentId])
  @@map("component_checks")
}

// ----- Clients -----
model Client {
  id              String   @id @default(cuid())
  code            String   @unique               // e.g. CLI001
  customerName    String   @map("customer_name")
  email           String?
  phone           String?
  customerType    String?  @map("customer_type")    // OEM | Retail | Dealer | etc.
  globalOrIndian  String?  @map("global_or_indian") // "Global" | "Indian"
  state           String?                           // e.g. "Gujarat" — for IGST vs CGST+SGST
  billingAddress  String?  @map("billing_address")
  shippingAddress String?  @map("shipping_address")
  gstNumber       String?  @map("gst_number")
  panNumber       String?  @map("pan_number")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  orders              Order[]
  proformaInvoices    ProformaInvoice[]
  invoices            Invoice[]
  returnRequests      ReturnRequest[]
  sampleRequests      SampleRequest[]
  implementationGoods ImplementationGood[]

  @@map("clients")
}

// ----- Orders -----
model Order {
  id                 String    @id @default(cuid())
  orderNumber        String    @unique @map("order_number")
  websiteOrderNumber String?   @map("website_order_number")
  clientId           String?   @map("client_id")
  productId          String    @map("product_id")
  quantity    Int
  dueDate     DateTime? @map("due_date")
  priority    Int       @default(0)  // higher = more urgent
  status      OrderStatus @default(ACTIVE)
  holdReason  String?   @map("hold_reason")
  voltage     String?   // e.g. "48V"
  motorType   MotorType?  @map("motor_type")
  harnessRequired  Boolean  @default(false) @map("harness_required")
  harnessProductId String?  @map("harness_product_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById String?   @map("created_by_id")

  client          Client?          @relation(fields: [clientId], references: [id])
  product         Product          @relation(fields: [productId], references: [id])
  units           ControllerUnit[]
  proformaInvoice ProformaInvoice?
  dispatches      Dispatch[]
  dispatchOrders  DispatchOrder[]
  returnRequests  ReturnRequest[]
  notes           OrderNote[]
  jobCards        JobCard[]
  harnessProduct  Product?       @relation("HarnessProduct", fields: [harnessProductId], references: [id])
  harnessUnits    HarnessUnit[]
}

model OrderNote {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  content   String
  authorId  String   @map("author_id")
  role      String   // SALES, PRODUCTION_MANAGER, ADMIN, etc.
  createdAt DateTime @default(now()) @map("created_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author User  @relation("OrderNoteAuthor", fields: [authorId], references: [id])

  @@map("order_notes")
}

enum OrderStatus {
  ACTIVE
  HOLD
  CANCELLED
  CLOSED
  DISPATCHED  // all units dispatched
}

enum MotorType {
  LBX
  UBX
}

// ----- Controller Unit (one per serial) -----
model ControllerUnit {
  id              String    @id @default(cuid())
  serialNumber    String    @unique @map("serial_number")  // SMX100026001
  orderId         String    @map("order_id")
  productId       String    @map("product_id")
  currentStage    StageType @map("current_stage")
  currentStatus   UnitStatus @map("current_status") @default(PENDING)
  firmwareVersion String?   @map("firmware_version")
  softwareVersion String?   @map("software_version")
  readyForDispatch Boolean  @default(false) @map("ready_for_dispatch")
  barcodeVerified  Boolean  @default(false) @map("barcode_verified") // trading items: true after barcode scan confirmation
  // Stage-wise barcodes
  powerstageBarcode    String?  @unique @map("powerstage_barcode")
  brainboardBarcode    String?  @unique @map("brainboard_barcode")
  assemblyBarcode      String?  @unique @map("assembly_barcode")
  qcBarcode            String?  @unique @map("qc_barcode")
  finalAssemblyBarcode String?  @unique @map("final_assembly_barcode")
  // New fields
  warrantyStartDate    DateTime? @map("warranty_start_date")
  warrantyMonths       Int?      @map("warranty_months")      // 12 for retail, 36 for OEM
  dispatchedAt         DateTime? @map("dispatched_at")
  returnRequestId      String?   @map("return_request_id")  // links replacement units to their ReturnRequest
  bluetoothCode        String?   @map("bluetooth_code")     // last 4 digits of BLE device, captured during QC
  pairedHarnessId      String?   @unique @map("paired_harness_id") // set during packing scan
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  order       Order    @relation(fields: [orderId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
  pairedHarness  HarnessUnit? @relation("PairedHarness", fields: [pairedHarnessId], references: [id])
  linkedReturnRequest ReturnRequest? @relation("ReplacementUnits", fields: [returnRequestId], references: [id])
  assignments StageAssignment[]
  stageLogs   StageLog[]
  qcRecords   QCRecord[]
  reworkRecords ReworkRecord[]
  timelineLogs TimelineLog[]
  componentChecks ComponentCheck[]
  workSubmissions StageWorkSubmission[]
  dispatchItems     DispatchItem[]
  packingBoxItem    PackingBoxItem?
  dispatchOrderScan DispatchOrderScan?
  returnRequests    ReturnRequest[]
  jobCards          JobCard[]
}

enum StageType {
  POWERSTAGE_MANUFACTURING
  BRAINBOARD_MANUFACTURING
  CONTROLLER_ASSEMBLY
  QC_AND_SOFTWARE
  REWORK
  FINAL_ASSEMBLY
}

enum UnitStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  WAITING_APPROVAL
  APPROVED
  REJECTED_BACK
  BLOCKED
}

// ----- Stage assignment (who is assigned to this unit at this stage) -----
model StageAssignment {
  id         String   @id @default(cuid())
  unitId     String   @map("unit_id")
  userId     String   @map("user_id")
  stage      StageType
  assignedAt DateTime @default(now()) @map("assigned_at")

  unit ControllerUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user User            @relation(fields: [userId], references: [id])
  @@unique([unitId, stage])
  @@map("stage_assignments")
}

// ----- Stage log (each time unit moves / status changes at a stage) -----
model StageLog {
  id          String    @id @default(cuid())
  unitId      String    @map("unit_id")
  userId      String?   @map("user_id")
  stage       StageType
  statusFrom  UnitStatus? @map("status_from")
  statusTo    UnitStatus  @map("status_to")
  approvedById String?   @map("approved_by_id")
  remarks     String?
  createdAt   DateTime  @default(now()) @map("created_at")

  unit        ControllerUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user        User?          @relation(fields: [userId], references: [id])
  approvedBy  User?          @relation("ApprovedBy", fields: [approvedById], references: [id])
  @@map("stage_logs")
}

// ----- QC records (pass/fail, detected at stage, source stage) -----
model QCRecord {
  id             String   @id @default(cuid())
  unitId         String   @map("unit_id")
  userId         String?  @map("user_id")
  result         QCResult  // PASS, FAIL
  detectedAtStage StageType @map("detected_at_stage")
  sourceStage    StageType? @map("source_stage")
  issueCategoryId String?  @map("issue_category_id")
  remarks        String?
  firmwareVersion String? @map("firmware_version")
  softwareVersion String? @map("software_version")
  checklistData  Json?   @map("checklist_data")
  createdAt      DateTime @default(now()) @map("created_at")

  unit           ControllerUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user           User?          @relation(fields: [userId], references: [id])
  issueCategory  IssueCategory? @relation(fields: [issueCategoryId], references: [id])
  @@map("qc_records")
}

enum QCResult {
  PASS
  FAIL
}

// ----- QC Test Checklist Config (per product) -----
model QCTestItem {
  id          String   @id @default(cuid())
  productId   String   @map("product_id")
  name        String                         // e.g. "Offset", "Motor Parameter", "Temp", "Bluetooth"
  sortOrder   Int      @default(0) @map("sort_order")
  requirePhoto Boolean @default(false) @map("require_photo")  // must upload photo for this item
  aiExtract   Boolean  @default(false) @map("ai_extract")     // AI auto-extracts param values from photo
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  product  Product       @relation(fields: [productId], references: [id])
  params   QCTestParam[]

  @@map("qc_test_items")
}

model QCTestParam {
  id          String   @id @default(cuid())
  testItemId  String   @map("test_item_id")
  name        String                         // e.g. "mcconf_foc_offsets_voltage_undriven", "R (mΩ)"
  label       String?                        // short display label, e.g. "Voltage Undriven"
  unit        String?                        // e.g. "mΩ", "°C", "%"
  minValue    Float?   @map("min_value")     // acceptable range min (null = no lower bound)
  maxValue    Float?   @map("max_value")     // acceptable range max (null = no upper bound)
  matchTolerance Float? @map("match_tolerance") // ±tolerance vs written value (e.g. 0.50 for R vs Motor Resistance)
  matchParamId   String? @map("match_param_id") // ID of param this must match within tolerance
  isWriteParam   Boolean @default(false) @map("is_write_param") // value written to controller (not read)
  hardBlock      Boolean @default(false) @map("hard_block")     // fail entire QC if out of range
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  testItem    QCTestItem  @relation(fields: [testItemId], references: [id], onDelete: Cascade)
  matchParam  QCTestParam? @relation("ParamMatch", fields: [matchParamId], references: [id])
  matchedBy   QCTestParam[] @relation("ParamMatch")

  @@map("qc_test_params")
}

// ----- Rework -----
model ReworkRecord {
  id              String   @id @default(cuid())
  unitId          String   @map("unit_id")
  assignedUserId  String?  @map("assigned_user_id")
  returnRequestId String?  @map("return_request_id")
  rootCauseStage  StageType? @map("root_cause_stage")
  rootCauseCategoryId String? @map("root_cause_category_id")
  correctiveAction String? @map("corrective_action")
  cycleCount      Int      @default(1) @map("cycle_count")
  status          ReworkStatus @default(OPEN)
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  unit        ControllerUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  assignedUser User?         @relation(fields: [assignedUserId], references: [id])
  returnRequest ReturnRequest? @relation(fields: [returnRequestId], references: [id])
  rootCauseCategory RootCauseCategory? @relation(fields: [rootCauseCategoryId], references: [id])
  @@map("rework_records")
}

enum ReworkStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  SENT_TO_QC
}

// ----- Timeline (permanent audit - never delete) -----
model TimelineLog {
  id         String   @id @default(cuid())
  unitId     String?  @map("unit_id")
  orderId    String?  @map("order_id")
  userId     String?  @map("user_id")
  action     String
  stage      StageType?
  statusFrom UnitStatus?
  statusTo   UnitStatus?
  remarks    String?
  metadata   String?  // JSON for extra context
  createdAt  DateTime @default(now()) @map("created_at")

  unit  ControllerUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  user  User?           @relation(fields: [userId], references: [id])
  @@map("timeline_logs")
}

// ----- Categories (settings) -----
model IssueCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  qcRecords QCRecord[]
  @@map("issue_categories")
}

model RootCauseCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  reworkRecords ReworkRecord[]
  @@map("root_cause_categories")
}

// ----- User performance (computed/cached scores) -----
model UserPerformanceSummary {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  periodFrom        DateTime @map("period_from")
  periodTo          DateTime @map("period_to")
  score             Float    // 0-100
  onTimeScore       Float    @map("on_time_score")
  productivityScore Float    @map("productivity_score")
  qualityScore      Float    @map("quality_score")
  disciplineScore   Float    @map("discipline_score")
  assignedCount     Int      @map("assigned_count")
  completedCount    Int      @map("completed_count")
  faultLinkedCount  Int      @map("fault_linked_count")
  reworkLinkedCount Int      @map("rework_linked_count")
  delayCount        Int      @map("delay_count")
  avgCompletionMinutes Int?  @map("avg_completion_minutes")
  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, periodFrom, periodTo])
  @@map("user_performance_summaries")
}

// ----- Stage Checklist Items -----
model StageChecklistItem {
  id                String    @id @default(cuid())
  productId         String?   @map("product_id")
  stage             StageType
  name              String
  description       String?
  referenceImageUrl String?   @map("reference_image_url")
  expectedCount     Int?      @map("expected_count")
  orientationRule   String?   @map("orientation_rule")
  boardLocation     String?   @map("board_location")
  componentPositions String?  @map("component_positions")
  photoZone         String?   @map("photo_zone")
  isBoardReference  Boolean   @default(false) @map("is_board_reference")
  required          Boolean   @default(true)
  sortOrder         Int       @default(0) @map("sort_order")
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  product           Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("stage_checklist_items")
}

// ----- Stage Work Submissions -----
model StageWorkSubmission {
  id              String            @id @default(cuid())
  unitId          String            @map("unit_id")
  employeeId      String            @map("employee_id")
  stage           StageType
  startedAt       DateTime          @default(now()) @map("started_at")
  submittedAt     DateTime?         @map("submitted_at")
  completedAt     DateTime?         @map("completed_at")
  buildTimeSec    Int?              @map("build_time_sec")
  imageUrl        String?           @map("image_url")
  imageUrl2       String?           @map("image_url_2")
  imageUrl3       String?           @map("image_url_3")
  analysisStatus  SubmissionStatus  @default(IN_PROGRESS) @map("analysis_status")
  analysisResult  SubmissionResult? @map("analysis_result")
  analysisIssues  String?           @map("analysis_issues")
  analysisSummary String?           @map("analysis_summary")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  unit     ControllerUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  employee User           @relation("WorkSubmissions", fields: [employeeId], references: [id])

  @@map("stage_work_submissions")
}

enum SubmissionStatus {
  IN_PROGRESS
  ANALYZING
  PASSED
  FAILED
}

enum SubmissionResult {
  PASS
  FAIL
}

// ----- Sales: Proforma Invoices -----
model ProformaInvoice {
  id               String         @id @default(cuid())
  invoiceNumber    String         @unique @map("invoice_number")  // TSM/PI/25-26/001
  invoiceDate      DateTime       @default(now()) @map("invoice_date")
  clientId         String         @map("client_id")
  invoiceType      InvoiceType    @default(SALE) @map("invoice_type")
  currency         String         @default("INR")
  exchangeRate     Float?         @map("exchange_rate")
  termsOfPayment   String?        @map("terms_of_payment")
  deliveryDays     Int?           @map("delivery_days")
  termsOfDelivery  String?        @map("terms_of_delivery")
  notes            String?
  paymentReceiptUrl  String?      @map("payment_receipt_url")
  declaredAmount     Float?       @map("declared_amount")      // amount SALES declares at submit-for-approval (ACCOUNTS verifies)
  status             ProformaStatus @default(DRAFT)
  rejectedReason     String?      @map("rejected_reason")
  clientPONumber     String?      @map("client_po_number")   // client's PO reference
  advanceAmount      Float?       @map("advance_amount")     // advance paid by client
  advancePaidAt      DateTime?    @map("advance_paid_at")
  createdById      String         @map("created_by_id")
  approvedById     String?        @map("approved_by_id")
  approvedAt       DateTime?      @map("approved_at")
  orderId          String?        @unique @map("order_id")
  relatedInvoiceId String?        @map("related_invoice_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  splitInvoice        Boolean  @default(false) @map("split_invoice")
  splitServicePercent Float?   @map("split_service_percent")
  shippingRoute       String?  @map("shipping_route")  // "AIR" | "LAND" — domestic only

  client         Client               @relation(fields: [clientId], references: [id])
  createdBy      User                 @relation("PICreatedBy", fields: [createdById], references: [id])
  approvedBy     User?                @relation("PIApprovedBy", fields: [approvedById], references: [id])
  order          Order?               @relation(fields: [orderId], references: [id])
  relatedInvoice ProformaInvoice?     @relation("RelatedInvoice", fields: [relatedInvoiceId], references: [id])
  relatedTo      ProformaInvoice[]    @relation("RelatedInvoice")
  items          ProformaInvoiceItem[]
  invoices       Invoice[]

  @@map("proforma_invoices")
}

enum InvoiceType {
  SALE
  RETURN
  REPLACEMENT
}

enum ProformaStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CONVERTED
}

model ProformaInvoiceItem {
  id              String   @id @default(cuid())
  proformaId      String   @map("proforma_id")
  description     String
  productId       String?  @map("product_id")
  hsnCode         String   @map("hsn_code")
  quantity        Int
  unitPrice       Float    @map("unit_price")
  discountPercent Float    @default(0) @map("discount_percent")
  sortOrder       Int      @default(0) @map("sort_order")
  voltageFrom     String?  @map("voltage_from")
  voltageTo       String?  @map("voltage_to")
  createdAt       DateTime @default(now()) @map("created_at")

  proforma ProformaInvoice @relation(fields: [proformaId], references: [id], onDelete: Cascade)
  product  Product?        @relation(fields: [productId], references: [id])

  @@map("proforma_invoice_items")
}

// ----- App Settings -----
model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  updatedById String?  @map("updated_by_id")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedBy User? @relation(fields: [updatedById], references: [id])

  @@map("app_settings")
}

// ----- Shipping Dispatch (legacy) -----
enum DispatchStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model Dispatch {
  id             String         @id @default(cuid())
  dispatchNumber String         @unique @map("dispatch_number")
  orderId        String         @map("order_id")
  status         DispatchStatus @default(DRAFT)
  isPartial      Boolean        @default(false) @map("is_partial")
  partialReason  String?        @map("partial_reason")
  dispatchedById String         @map("dispatched_by_id")
  approvedById   String?        @map("approved_by_id")
  boxPhotoUrl    String?        @map("box_photo_url")
  submittedAt    DateTime?      @map("submitted_at")
  approvedAt     DateTime?      @map("approved_at")
  rejectedReason String?        @map("rejected_reason")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  order        Order          @relation(fields: [orderId], references: [id])
  dispatchedBy User           @relation("DispatchedBy", fields: [dispatchedById], references: [id])
  approvedBy   User?          @relation("DispatchApprovedBy", fields: [approvedById], references: [id])
  items        DispatchItem[]

  @@map("dispatches")
}

model DispatchItem {
  id                 String    @id @default(cuid())
  dispatchId         String    @map("dispatch_id")
  unitId             String    @map("unit_id")
  serial             String
  barcode            String
  controllerPhotoUrl String?   @map("controller_photo_url")
  scannedAt          DateTime  @default(now()) @map("scanned_at")
  scannedById        String    @map("scanned_by_id")

  dispatch  Dispatch       @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  unit      ControllerUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  scannedBy User           @relation("DispatchItemScannedBy", fields: [scannedById], references: [id])

  @@unique([dispatchId, unitId])
  @@map("dispatch_items")
}

// ----- Dispatch Orders (employee-created, multi-box packing) -----
enum DOStatus {
  OPEN
  PACKING
  SUBMITTED
  APPROVED
  REJECTED
}

model DispatchOrder {
  id              String    @id @default(cuid())
  doNumber        String    @unique @map("do_number")   // TSM/DO/26-27/0001
  orderId         String?   @map("order_id")
  returnRequestId String?   @map("return_request_id")
  status          DOStatus  @default(OPEN)
  dispatchQty     Int       @default(0) @map("dispatch_qty")
  totalBoxes      Int?      @map("total_boxes")
  submittedAt     DateTime? @map("submitted_at")
  approvedAt      DateTime? @map("approved_at")
  rejectedReason  String?   @map("rejected_reason")
  createdById     String    @map("created_by_id")
  approvedById    String?   @map("approved_by_id")
  reworkUnitPrice Float?    @map("rework_unit_price")  // manual price for customer damage invoices
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  order         Order?         @relation(fields: [orderId], references: [id])
  returnRequest ReturnRequest? @relation(fields: [returnRequestId], references: [id])
  createdBy     User           @relation("DOCreatedBy", fields: [createdById], references: [id])
  approvedBy    User?          @relation("DOApprovedBy", fields: [approvedById], references: [id])
  boxes         PackingBox[]
  scans         DispatchOrderScan[]
  invoices      Invoice[]

  @@map("dispatch_orders")
}

model BoxSize {
  id        String   @id @default(cuid())
  name      String
  lengthCm  Float    @map("length_cm")
  widthCm   Float    @map("width_cm")
  heightCm  Float    @map("height_cm")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  boxes PackingBox[]

  @@map("box_sizes")
}

model PackingBox {
  id              String        @id @default(cuid())
  dispatchOrderId String        @map("dispatch_order_id")
  boxNumber       Int           @map("box_number")
  boxLabel        String        @map("box_label")  // TSM/DO/26-27/0001-BOX-1of3
  photoUrl        String?       @map("photo_url")
  isSealed        Boolean       @default(false) @map("is_sealed")
  labelScanned    Boolean       @default(false) @map("label_scanned")
  weightKg        Float?        @map("weight_kg")
  boxSizeId       String?       @map("box_size_id")
  createdAt       DateTime      @default(now()) @map("created_at")

  dispatchOrder DispatchOrder   @relation(fields: [dispatchOrderId], references: [id], onDelete: Cascade)
  boxSize       BoxSize?        @relation(fields: [boxSizeId], references: [id])
  items         PackingBoxItem[]

  @@unique([dispatchOrderId, boxNumber])
  @@map("packing_boxes")
}

model PackingBoxItem {
  id                  String         @id @default(cuid())
  boxId               String         @map("box_id")
  unitId              String         @unique @map("unit_id")  // one unit → one box only
  serial              String
  barcode             String
  scannedAt           DateTime       @default(now()) @map("scanned_at")
  scannedById         String         @map("scanned_by_id")
  inspectionPhotoUrl  String?        @map("inspection_photo_url")  // photo taken during packing inspection

  box       PackingBox     @relation(fields: [boxId], references: [id], onDelete: Cascade)
  unit      ControllerUnit @relation(fields: [unitId], references: [id])
  scannedBy User           @relation("BoxItemScannedBy", fields: [scannedById], references: [id])

  @@map("packing_box_items")
}

// ----- Dispatch Order Scans (staging: scanned before boxes are created) -----
model DispatchOrderScan {
  id                 String   @id @default(cuid())
  dispatchOrderId    String   @map("dispatch_order_id")
  unitId             String   @unique @map("unit_id")  // one unit staged per DO only
  serial             String
  barcode            String
  inspectionPhotoUrl String?  @map("inspection_photo_url")
  scannedById        String   @map("scanned_by_id")
  scannedAt          DateTime @default(now()) @map("scanned_at")

  dispatchOrder DispatchOrder  @relation(fields: [dispatchOrderId], references: [id], onDelete: Cascade)
  unit          ControllerUnit @relation(fields: [unitId], references: [id])
  scannedBy     User           @relation("DOScanScannedBy", fields: [scannedById], references: [id])

  @@map("dispatch_order_scans")
}

// ----- Tax Invoice (auto-generated on DO approval) -----
enum InvoiceStatus {
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum InvoiceSubType {
  FULL     // normal invoice, no split
  GOODS    // split invoice: goods portion only
  SERVICE  // split invoice: service portion only
}

model Invoice {
  id               String         @id @default(cuid())
  invoiceNumber    String         @unique @map("invoice_number")
  dispatchOrderId  String         @map("dispatch_order_id")
  proformaId       String?        @map("proforma_id")
  subType          InvoiceSubType @default(FULL) @map("sub_type")
  splitPercent     Float?         @map("split_percent")
  relatedInvoiceId String?        @map("related_invoice_id")
  clientId         String         @map("client_id")
  currency         String         @default("INR")
  exchangeRate     Float?         @map("exchange_rate")
  notes            String?
  // Payment tracking
  status           InvoiceStatus  @default(APPROVED) @map("status")  // APPROVED default for existing invoices
  totalAmount      Float          @default(0) @map("total_amount")   // stored at creation
  paidAmount       Float          @default(0) @map("paid_amount")
  dueDate          DateTime?      @map("due_date")
  approvedById     String?        @map("approved_by_id")
  approvedAt       DateTime?      @map("approved_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  dispatchOrder  DispatchOrder    @relation(fields: [dispatchOrderId], references: [id])
  proforma       ProformaInvoice? @relation(fields: [proformaId], references: [id])
  relatedInvoice Invoice?         @relation("SplitInvoice", fields: [relatedInvoiceId], references: [id])
  relatedTo      Invoice[]        @relation("SplitInvoice")
  client         Client           @relation(fields: [clientId], references: [id])
  approvedBy     User?            @relation("InvoiceApprovedBy", fields: [approvedById], references: [id])
  items          InvoiceItem[]
  payments       Payment[]

  @@map("invoices")
}

model InvoiceItem {
  id              String  @id @default(cuid())
  invoiceId       String  @map("invoice_id")
  description     String
  hsnCode         String  @map("hsn_code")
  quantity        Int
  unitPrice       Float   @map("unit_price")
  discountPercent Float   @default(0) @map("discount_percent")
  sortOrder       Int     @default(0) @map("sort_order")
  serialNumbers   String? @map("serial_numbers")  // JSON array: ["SMX1000260001", ...]

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

// ----- Payments (against Tax Invoices) -----
model Payment {
  id            String   @id @default(cuid())
  paymentNumber String   @unique @map("payment_number")  // PAY/26-27/001
  invoiceId     String   @map("invoice_id")
  amount        Float
  currency      String   @default("INR")
  paymentDate   DateTime @map("payment_date")
  method        String   // BANK_TRANSFER, CHEQUE, CASH, UPI, SWIFT
  reference     String?  // transaction ref, cheque number
  recordedById  String   @map("recorded_by_id")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  recordedBy User    @relation(fields: [recordedById], references: [id])

  @@map("payments")
}

// ----- Returns & Warranty -----
enum ReturnStatus {
  REPORTED
  EVALUATED
  APPROVED
  UNIT_RECEIVED
  IN_REPAIR
  REPAIRED
  QC_CHECKED
  DISPATCHED
  CLOSED
  REJECTED
}

model ReturnRequest {
  id              String       @id @default(cuid())
  returnNumber    String       @unique @map("return_number")  // RTN/26-27/001
  clientId        String       @map("client_id")
  unitId          String?      @map("unit_id")
  orderId         String?      @map("order_id")
  serialNumber    String?      @map("serial_number")  // manual entry if unit not in system
  type            String       // WARRANTY, DAMAGE, WRONG_ITEM, OTHER
  reportedIssue   String       @map("reported_issue")
  status          ReturnStatus @default(REPORTED)
  reportedById    String       @map("reported_by_id")
  evaluatedById   String?      @map("evaluated_by_id")
  evaluationNotes String?      @map("evaluation_notes")
  resolution      String?      // REPAIR, REPLACE, REFUND, CREDIT_NOTE
  proformaId      String?      @map("proforma_id")  // linked replacement/return PI
  batchId         String?      @map("batch_id")     // groups multiple units submitted together
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Fault determination
  faultType           String?    @map("fault_type")           // MANUFACTURING_DEFECT | CUSTOMER_DAMAGE
  faultApproval       String?    @map("fault_approval")       // PENDING | APPROVED | REJECTED
  faultApprovedById   String?    @map("fault_approved_by_id")
  blameEmployeeId     String?    @map("blame_employee_id")
  blameStage          StageType? @map("blame_stage")
  blameDate           DateTime?  @map("blame_date")
  // Inspection photos
  topPhotoUrl         String?    @map("top_photo_url")
  bbInspectionPhotoUrl String?   @map("bb_inspection_photo_url")
  psInspectionPhotoUrl String?   @map("ps_inspection_photo_url")

  client         Client          @relation(fields: [clientId], references: [id])
  unit           ControllerUnit? @relation(fields: [unitId], references: [id])
  order          Order?          @relation(fields: [orderId], references: [id])
  reportedBy     User            @relation("ReturnReportedBy", fields: [reportedById], references: [id])
  evaluatedBy    User?           @relation("ReturnEvaluatedBy", fields: [evaluatedById], references: [id])
  faultApprovedBy User?          @relation("ReturnFaultApprovedBy", fields: [faultApprovedById], references: [id])
  blameEmployee  User?           @relation("ReturnBlameEmployee", fields: [blameEmployeeId], references: [id])
  repairLogs       RepairLog[]
  reworkRecords    ReworkRecord[]
  dispatchOrders   DispatchOrder[]
  materials        ReworkMaterial[]
  replacementUnits ControllerUnit[] @relation("ReplacementUnits")

  @@map("return_requests")
}

model RepairLog {
  id              String    @id @default(cuid())
  returnRequestId String    @map("return_request_id")
  unitId          String?   @map("unit_id")
  issue           String
  workDone        String?   @map("work_done")
  beforePhotoUrl  String?   @map("before_photo_url")
  boardPhotoUrl   String?   @map("board_photo_url")
  powerstagePhotoUrl String? @map("powerstage_photo_url")
  afterPhotoUrl   String?   @map("after_photo_url")
  employeeId      String    @map("employee_id")
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  employee      User          @relation(fields: [employeeId], references: [id])

  @@map("repair_logs")
}

model ReworkMaterial {
  id              String    @id @default(cuid())
  returnRequestId String    @map("return_request_id")
  rawMaterialId   String    @map("raw_material_id")
  materialName    String    @map("material_name")
  unit            String
  qtyRequested    Float     @map("qty_requested")
  qtyIssued       Float     @default(0) @map("qty_issued")
  status          String    @default("PENDING")
  notes           String?
  requestedById   String    @map("requested_by_id")
  issuedById      String?   @map("issued_by_id")
  issuedAt        DateTime? @map("issued_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  rawMaterial   RawMaterial   @relation(fields: [rawMaterialId], references: [id])
  requestedBy   User          @relation("ReworkMaterialRequestedBy", fields: [requestedById], references: [id])
  issuedBy      User?         @relation("ReworkMaterialIssuedBy", fields: [issuedById], references: [id])

  @@map("rework_materials")
}

// ----- Inventory -----

model UnitOfMeasure {
  id        String   @id @default(cuid())
  name      String   // "Pieces", "Reel", "Kilogram"
  symbol    String   @unique // "PCS", "REEL", "KG"
  type      String   @default("QUANTITY") // QUANTITY, WEIGHT, VOLUME, LENGTH
  createdAt DateTime @default(now()) @map("created_at")

  @@map("units_of_measure")
}

model MaterialCategory {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique  // barcode prefix e.g. CAP, PCB, MOS, RES
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  materials RawMaterial[]

  @@map("material_categories")
}

model RawMaterial {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  description       String?
  unit              String   // base/stock unit e.g. PCS (how stock is tracked & consumed)
  purchaseUnit      String?  @map("purchase_unit")      // purchase unit e.g. REEL (if different from stock unit)
  conversionFactor  Float?   @map("conversion_factor")  // how many stock units per purchase unit e.g. 2000 PCS per REEL
  hsnCode           String?  @map("hsn_code")
  purchasePrice     Float    @default(0) @map("purchase_price")
  lastPurchasePrice Float?   @map("last_purchase_price")        // actual last PO unit price (updated on GRN)
  lastPurchasedAt   DateTime? @map("last_purchased_at")
  lastPurchasedFrom String?  @map("last_purchased_from")        // vendor name for display
  aiPriceBenchmark  Float?   @map("ai_price_benchmark")         // AI estimated fair price for first purchase
  leadTimeDays      Int      @default(0) @map("lead_time_days")
  currentStock      Float    @default(0) @map("current_stock")
  minimumStock      Float    @default(0) @map("minimum_stock")
  reorderPoint      Float    @default(0) @map("reorder_point")
  minimumOrderQty   Float    @default(1) @map("minimum_order_qty")
  categoryId        String?  @map("category_id")
  preferredVendorId String?  @map("preferred_vendor_id")
  active            Boolean  @default(true)
  barcode           String?  @unique
  productionStage   String?  @map("production_stage")  // "PS" | "BB" | null — for individual serial tracking at GRN
  packSize          Int      @default(1) @map("pack_size")          // units per pack for serial labeling at GRN (1 = individual)
  batchTracking     Boolean  @default(false) @map("batch_tracking")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  category         MaterialCategory?  @relation(fields: [categoryId], references: [id])
  preferredVendor  Vendor?            @relation("PreferredVendor", fields: [preferredVendorId], references: [id])
  bomItems         BOMItem[]
  stockMovements   StockMovement[]
  poItems          POItem[]
  receiptItems     GoodsReceiptItem[]
  purchaseRequests PurchaseRequest[]
  batches          InventoryBatch[]
  jobCardItems     JobCardItem[]
  variants         MaterialVariant[]
  roItems          RequirementOrderItem[]
  rfqItems         RFQItem[]
  quoteItems       VendorQuoteItem[]
  ganItems         GANItem[]
  damageReports    DamageReport[]
  materialSerials  MaterialSerial[]
  reworkMaterials  ReworkMaterial[]

  @@map("raw_materials")
}

model MaterialVariant {
  id           String      @id @default(cuid())
  materialId   String      @map("material_id")
  name         String      // e.g. "25V", "50V", "2000pcs/reel"
  barcode      String      @unique
  currentStock Float       @default(0) @map("current_stock")
  notes        String?
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now()) @map("created_at")

  material RawMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@map("material_variants")
}

model BOMItem {
  id               String     @id @default(cuid())
  productId        String     @map("product_id")
  rawMaterialId    String     @map("raw_material_id")
  voltage          String?    // null = applies to all voltages
  stage            StageType? // which production stage consumes this
  quantityRequired Float      @map("quantity_required")
  unit             String
  isCritical       Boolean    @default(false) @map("is_critical") // must be in stock to dispatch
  notes            String?

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@unique([productId, rawMaterialId, voltage])
  @@map("bom_items")
}

model StockMovement {
  id             String   @id @default(cuid())
  rawMaterialId  String   @map("raw_material_id")
  type           String   // IN, OUT, ADJUSTMENT
  quantity       Float
  reference      String?  // PO number, order number, etc.
  adjustmentType String?  @map("adjustment_type") // DAMAGE | THEFT | EXPIRY | CORRECTION | FOUND | OPENING | PHYSICAL_COUNT | PRODUCTION | SCRAP | SAMPLE | RETURN_TO_VENDOR | OTHER
  notes          String?
  createdById    String   @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id])
  createdBy   User        @relation(fields: [createdById], references: [id])

  @@map("stock_movements")
}

// ----- Purchase -----
enum PurchaseRequestStatus {
  DRAFT
  OPEN
  BIDDING
  AWARDED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED          // PM approved the PO
  SENT              // sent to vendor
  CONFIRMED         // vendor confirmed
  GOODS_ARRIVED     // PM created GAN
  PARTIALLY_RECEIVED
  RECEIVED          // all GRN done
  CANCELLED
}

model VendorCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("vendor_categories")
}

model Vendor {
  id              String   @id @default(cuid())
  code            String   @unique  // V001, V002...
  name            String
  contactPerson   String?  @map("contact_person")
  phone           String?
  email           String?
  address         String?
  gstNumber       String?  @map("gst_number")
  active          Boolean  @default(true)
  rating          Float?   // 1-5 rating (legacy, use VendorPerformance)
  // Vendor portal
  portalEmail     String?  @unique @map("portal_email")
  portalPassword  String?  @map("portal_password")  // bcrypt hashed
  isPortalActive  Boolean  @default(false) @map("is_portal_active")
  // Categories they supply (array of category names)
  categories      String[] @default([])
  bankName        String?  @map("bank_name")
  bankAccount     String?  @map("bank_account")
  ifscCode        String?  @map("ifsc_code")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  purchaseOrders   PurchaseOrder[]
  bidInvitations   BidInvitation[]
  bids             VendorBid[]
  preferredFor     RawMaterial[]   @relation("PreferredVendor")
  rfqInvites       RFQVendorInvite[]
  quotes           VendorQuote[]
  performance      VendorPerformance[]
  vendorInvoices   VendorInvoice[]

  @@map("vendors")
}

model PurchaseRequest {
  id               String                @id @default(cuid())
  requestNumber    String                @unique @map("request_number")  // PR/26-27/001
  rawMaterialId    String                @map("raw_material_id")
  quantityRequired Float                 @map("quantity_required")
  unit             String
  urgency          String                @default("MEDIUM")  // LOW, MEDIUM, HIGH, CRITICAL
  status           PurchaseRequestStatus @default(DRAFT)
  notes            String?
  requestedById    String                @map("requested_by_id")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  rawMaterial    RawMaterial     @relation(fields: [rawMaterialId], references: [id])
  requestedBy    User            @relation(fields: [requestedById], references: [id])
  bidInvitations BidInvitation[]
  bids           VendorBid[]
  purchaseOrders PurchaseOrder[]

  @@map("purchase_requests")
}

model BidInvitation {
  id                String   @id @default(cuid())
  purchaseRequestId String   @map("purchase_request_id")
  vendorId          String   @map("vendor_id")
  token             String   @unique  // UUID for vendor portal access
  deadline          DateTime
  invitedAt         DateTime @default(now()) @map("invited_at")
  status            String   @default("PENDING")  // PENDING, SUBMITTED, EXPIRED

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  vendor          Vendor          @relation(fields: [vendorId], references: [id])
  bid             VendorBid?

  @@unique([purchaseRequestId, vendorId])
  @@map("bid_invitations")
}

model VendorBid {
  id                String   @id @default(cuid())
  bidInvitationId   String   @unique @map("bid_invitation_id")
  purchaseRequestId String   @map("purchase_request_id")
  vendorId          String   @map("vendor_id")
  pricePerUnit      Float    @map("price_per_unit")
  totalAmount       Float    @map("total_amount")
  leadTimeDays      Int      @map("lead_time_days")
  validUntil        DateTime @map("valid_until")
  attachmentUrl     String?  @map("attachment_url")
  notes             String?
  submittedAt       DateTime @default(now()) @map("submitted_at")
  status            String   @default("PENDING")  // PENDING, SELECTED, REJECTED

  bidInvitation   BidInvitation   @relation(fields: [bidInvitationId], references: [id], onDelete: Cascade)
  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id])
  vendor          Vendor          @relation(fields: [vendorId], references: [id])

  @@map("vendor_bids")
}

model PurchaseOrder {
  id                String              @id @default(cuid())
  poNumber          String              @unique @map("po_number")  // PO/26-27/001
  vendorId          String              @map("vendor_id")
  purchaseRequestId String?             @map("purchase_request_id")  // legacy, optional
  rfqId             String?             @map("rfq_id")               // new flow: from RFQ
  selectedQuoteId   String?             @map("selected_quote_id")    // winning VendorQuote id
  status            PurchaseOrderStatus @default(DRAFT)
  expectedDelivery  DateTime?           @map("expected_delivery")
  totalAmount       Float               @map("total_amount")
  currency          String              @default("INR")
  notes             String?
  approvedById      String?             @map("approved_by_id")
  approvedAt        DateTime?           @map("approved_at")
  createdById       String              @map("created_by_id")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  paidAmount        Float               @default(0) @map("paid_amount")
  paymentStatus     String              @default("UNPAID") @map("payment_status")

  vendor          Vendor             @relation(fields: [vendorId], references: [id])
  purchaseRequest PurchaseRequest?   @relation(fields: [purchaseRequestId], references: [id])
  rfq             RFQ?               @relation(fields: [rfqId], references: [id])
  createdBy       User               @relation(fields: [createdById], references: [id])
  approvedBy      User?              @relation("POApprovedBy", fields: [approvedById], references: [id])
  items           POItem[]
  receipts        GoodsReceipt[]
  goodsArrivals   GoodsArrivalNote[]
  performance     VendorPerformance[]
  vendorInvoices  VendorInvoice[]
  paymentRequest  PaymentRequest?

  @@map("purchase_orders")
}

model POItem {
  id               String  @id @default(cuid())
  purchaseOrderId  String  @map("purchase_order_id")
  rawMaterialId    String? @map("raw_material_id")   // null for custom/description items
  itemDescription  String? @map("item_description")  // for custom items without a material
  itemUnit         String? @map("item_unit")          // unit for custom items
  quantity         Float
  unitPrice        Float   @map("unit_price")
  receivedQuantity Float   @default(0) @map("received_quantity")

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  rawMaterial   RawMaterial?       @relation(fields: [rawMaterialId], references: [id])
  receiptItems  GoodsReceiptItem[]
  batches       InventoryBatch[]
  ganItems      GANItem[]

  @@map("po_items")
}

model GoodsReceipt {
  id              String   @id @default(cuid())
  grnNumber       String   @unique @map("grn_number")  // GRN/26-27/001
  purchaseOrderId String   @map("purchase_order_id")
  ganId           String?  @unique @map("gan_id")       // linked GAN (new flow)
  receivedById    String   @map("received_by_id")
  receivedAt      DateTime @default(now()) @map("received_at")
  notes           String?

  purchaseOrder PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id])
  gan           GoodsArrivalNote? @relation(fields: [ganId], references: [id])
  receivedBy    User               @relation(fields: [receivedById], references: [id])
  items           GoodsReceiptItem[]
  batches         InventoryBatch[]
  materialSerials MaterialSerial[]

  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id             String  @id @default(cuid())
  goodsReceiptId String  @map("goods_receipt_id")
  poItemId       String  @map("po_item_id")
  rawMaterialId  String  @map("raw_material_id")
  quantity       Float
  unitPrice      Float   @default(0) @map("unit_price")
  condition      String  @default("GOOD")  // GOOD, DAMAGED, REJECTED

  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  poItem       POItem       @relation(fields: [poItemId], references: [id])
  rawMaterial  RawMaterial  @relation(fields: [rawMaterialId], references: [id])

  @@map("goods_receipt_items")
}

model InventoryBatch {
  id                String    @id @default(cuid())
  batchCode         String    @unique @map("batch_code")  // BATCH/26-27/001
  rawMaterialId     String    @map("raw_material_id")
  goodsReceiptId    String?   @map("goods_receipt_id")   // null for opening stock / adjustments
  poItemId          String?   @map("po_item_id")
  quantity          Float                                 // original quantity received
  remainingQty      Float     @map("remaining_qty")      // decrements on FIFO consumption
  unitPrice         Float     @default(0) @map("unit_price")
  condition         String    @default("GOOD")            // GOOD, DAMAGED, REJECTED
  manufacturingDate DateTime? @map("manufacturing_date")
  expiryDate        DateTime? @map("expiry_date")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")

  rawMaterial  RawMaterial   @relation(fields: [rawMaterialId], references: [id])
  goodsReceipt GoodsReceipt? @relation(fields: [goodsReceiptId], references: [id])
  poItem       POItem?       @relation(fields: [poItemId], references: [id])
  jobCardItems  JobCardItem[]
  damageReports DamageReport[] @relation("BatchDamages")

  @@map("inventory_batches")
}

// ----- Attendance & Shifts -----
model AttendanceRecord {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  date        DateTime  @map("date") @db.Date
  clockInAt   DateTime? @map("clock_in_at")
  clockOutAt  DateTime? @map("clock_out_at")
  hoursWorked Float?    @map("hours_worked")
  isOvertime  Boolean   @default(false) @map("is_overtime")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("attendance_records")
}

// ----- Notifications -----
model Notification {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  type         String   // APPROVAL_REQUIRED, QC_FAILURE, REWORK_AGING, DISPATCH_APPROVED, etc.
  title        String
  message      String
  isRead       Boolean  @default(false) @map("is_read")
  relatedModel String?  @map("related_model")  // invoice, order, unit, return, etc.
  relatedId    String?  @map("related_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ----- Audit -----
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  details   String?  // JSON
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])
  @@map("audit_logs")
}

// ----- Job Cards (production material issuance) -----
enum JobCardStatus {
  PENDING       // job card created, waiting for IM to dispatch
  DISPATCHED    // IM has scanned and dispatched materials
  IN_PROGRESS   // PE is working
  COMPLETED
  CANCELLED
}

enum DispatchType {
  FULL
  PARTIAL
}

model JobCard {
  id            String        @id @default(cuid())
  cardNumber    String        @unique @map("card_number")
  orderId       String        @map("order_id")
  unitId        String?       @map("unit_id")   // null = order-level card
  orderQuantity Int           @default(1) @map("order_quantity")
  stage         StageType
  status        JobCardStatus @default(PENDING)
  dispatchType  DispatchType? @map("dispatch_type") // FULL or PARTIAL, set on dispatch
  notes         String?
  createdById   String        @map("created_by_id")
  dispatchedById String?      @map("dispatched_by_id")
  dispatchedAt  DateTime?     @map("dispatched_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  order            Order             @relation(fields: [orderId], references: [id])
  unit             ControllerUnit?   @relation(fields: [unitId], references: [id])
  createdBy        User              @relation("JCCreatedBy", fields: [createdById], references: [id])
  dispatchedBy     User?             @relation("JCDispatchedBy", fields: [dispatchedById], references: [id])
  items            JobCardItem[]
  requirementOrders RequirementOrder[] @relation("JobCardRO")
  damageReports     DamageReport[]

  @@unique([orderId, stage])
  @@map("job_cards")
}

model JobCardItem {
  id             String  @id @default(cuid())
  jobCardId      String  @map("job_card_id")
  rawMaterialId  String  @map("raw_material_id")
  batchId        String? @map("batch_id")
  quantityReq    Float   @map("quantity_required")
  quantityIssued Float   @default(0) @map("quantity_issued")
  isCritical     Boolean @default(false) @map("is_critical") // copied from BOMItem on job card creation
  verifiedQty    Float   @default(0) @map("verified_qty")   // employee scans/confirms after receiving
  isVerified     Boolean @default(false) @map("is_verified")
  returnedQty    Float   @default(0) @map("returned_qty")  // returned to store after job

  jobCard         JobCard         @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  rawMaterial     RawMaterial     @relation(fields: [rawMaterialId], references: [id])
  batch           InventoryBatch? @relation(fields: [batchId], references: [id])
  consumedSerials MaterialSerial[]

  @@map("job_card_items")
}

// ============================================================
// PROCUREMENT — NEW FLOW
// RO → RFQ → Vendor Quotes → PO → GAN → GRN
// ============================================================

enum ROStatus {
  PENDING    // auto-created, waiting IM approval
  APPROVED   // IM approved → visible to PM
  CONVERTED  // PM included in RFQ
  CANCELLED
}

enum ROTrigger {
  LOW_STOCK  // currentStock fell below minimumOrderQty
  JOB_CARD   // job card needed a component
  MANUAL     // created manually by IM
}

model RequirementOrder {
  id           String    @id @default(cuid())
  roNumber     String    @unique @map("ro_number")  // RO/26-27/001
  trigger      ROTrigger @default(MANUAL)
  jobCardId    String?   @map("job_card_id")
  status       ROStatus  @default(PENDING)
  notes        String?
  approvedById String?   @map("approved_by_id")
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  jobCard    JobCard?               @relation("JobCardRO", fields: [jobCardId], references: [id])
  approvedBy User?                  @relation("ROApprovedBy", fields: [approvedById], references: [id])
  items      RequirementOrderItem[]

  @@map("requirement_orders")
}

model RequirementOrderItem {
  id              String  @id @default(cuid())
  roId            String  @map("ro_id")
  materialId      String? @map("material_id")        // null for free-text items
  materialName    String? @map("material_name")       // snapshot at creation — preserved if material deleted
  itemDescription String? @map("item_description")   // for maintenance/consumables not in inventory
  itemUnit        String? @map("item_unit")           // e.g. pcs, kg, ltr
  qtyRequired     Float   @map("qty_required")
  qtyOrdered      Float   @default(0) @map("qty_ordered")
  notes           String?

  ro       RequirementOrder  @relation(fields: [roId], references: [id], onDelete: Cascade)
  material RawMaterial?      @relation(fields: [materialId], references: [id])
  rfqItems RFQItem[]

  @@map("requirement_order_items")
}

enum RFQStatus {
  DRAFT      // PM preparing, not sent yet
  OPEN       // sent to vendors, accepting quotes
  CLOSED     // deadline passed
  CONVERTED  // PO created
  CANCELLED
}

model RFQ {
  id          String    @id @default(cuid())
  rfqNumber   String    @unique @map("rfq_number")  // RFQ/26-27/001
  title       String
  description String?
  fileUrls    String[]  @default([]) @map("file_urls")  // drawings, specs, PDFs
  deadline    DateTime?
  paymentTerms String?  @map("payment_terms")
  category    String?   @map("category")              // vendor category this RFQ targets
  status      RFQStatus @default(DRAFT)
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  createdBy      User              @relation("RFQCreatedBy", fields: [createdById], references: [id])
  items          RFQItem[]
  vendorInvites  RFQVendorInvite[]
  quotes         VendorQuote[]
  purchaseOrders PurchaseOrder[]

  @@map("rfqs")
}

model RFQItem {
  id              String  @id @default(cuid())
  rfqId           String  @map("rfq_id")
  roItemId        String  @map("ro_item_id")
  materialId      String? @map("material_id")       // null for custom/maintenance items
  itemDescription String? @map("item_description")  // used when materialId is null
  itemUnit        String? @map("item_unit")          // unit for custom items
  qtyRequired     Float   @map("qty_required")

  rfq        RFQ                  @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  roItem     RequirementOrderItem @relation(fields: [roItemId], references: [id])
  material   RawMaterial?         @relation(fields: [materialId], references: [id])
  quoteItems VendorQuoteItem[]

  @@map("rfq_items")
}

model RFQVendorInvite {
  id        String    @id @default(cuid())
  rfqId     String    @map("rfq_id")
  vendorId  String    @map("vendor_id")
  token     String    @unique @default(cuid())  // secure token for vendor portal link
  invitedAt DateTime  @default(now()) @map("invited_at")
  viewedAt  DateTime? @map("viewed_at")

  rfq    RFQ    @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@unique([rfqId, vendorId])
  @@map("rfq_vendor_invites")
}

enum QuoteStatus {
  SUBMITTED
  SELECTED
  REJECTED
}

model VendorQuote {
  id           String      @id @default(cuid())
  rfqId        String      @map("rfq_id")
  vendorId     String      @map("vendor_id")
  currency     String      @default("INR")
  totalAmount  Float       @map("total_amount")
  leadTimeDays Int         @map("lead_time_days")
  validUntil   DateTime    @map("valid_until")
  notes        String?
  fileUrls     String[]    @default([]) @map("file_urls")  // vendor's quotation doc
  status       QuoteStatus @default(SUBMITTED)
  submittedAt  DateTime    @default(now()) @map("submitted_at")
  sampleStatus      String    @default("NONE") @map("sample_status")       // NONE, REQUESTED, APPROVED, REJECTED
  sampleRequestedAt DateTime? @map("sample_requested_at")
  sampleNotes       String?   @map("sample_notes")

  rfq    RFQ              @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendor Vendor           @relation(fields: [vendorId], references: [id])
  items  VendorQuoteItem[]

  @@unique([rfqId, vendorId])
  @@map("vendor_quotes")
}

model VendorQuoteItem {
  id         String  @id @default(cuid())
  quoteId    String  @map("quote_id")
  rfqItemId  String  @map("rfq_item_id")
  materialId String? @map("material_id")   // null for custom/maintenance items
  unitPrice  Float   @map("unit_price")
  currency   String  @default("INR")
  totalPrice Float   @map("total_price")
  notes      String?

  quote      VendorQuote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  rfqItem    RFQItem      @relation(fields: [rfqItemId], references: [id])
  material   RawMaterial? @relation(fields: [materialId], references: [id])
  breakdowns VendorQuoteItemBreakdown[]

  @@map("vendor_quote_items")
}

// Admin defines price breakdown factors per vendor category
model PriceBreakdownFactor {
  id          String   @id @default(cuid())
  name        String                           // "Material Cost", "Labor", "Overhead", etc.
  description String?
  category    String?                          // vendor category this applies to; null = all categories
  isRequired  Boolean  @default(true)  @map("is_required")
  order       Int      @default(0)             // display order
  active      Boolean  @default(true)
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  createdBy  User                       @relation(fields: [createdById], references: [id])
  breakdowns VendorQuoteItemBreakdown[]

  @@map("price_breakdown_factors")
}

// Vendor fills breakdown per item when submitting quote
model VendorQuoteItemBreakdown {
  id          String @id @default(cuid())
  quoteItemId String @map("quote_item_id")
  factorId    String @map("factor_id")
  amount      Float

  quoteItem VendorQuoteItem      @relation(fields: [quoteItemId], references: [id], onDelete: Cascade)
  factor    PriceBreakdownFactor @relation(fields: [factorId], references: [id])

  @@unique([quoteItemId, factorId])
  @@map("vendor_quote_item_breakdowns")
}

// Individual payment records (supports advance + final + partial)
model VendorPayment {
  id               String   @id @default(cuid())
  paymentRequestId String   @map("payment_request_id")
  type             String                             // ADVANCE, FINAL, PARTIAL
  amount           Float
  paymentMode      String?  @map("payment_mode")      // NEFT, RTGS, CHEQUE, UPI
  paymentRef       String?  @map("payment_ref")
  paymentDate      DateTime @map("payment_date")
  notes            String?
  processedById    String   @map("processed_by_id")
  createdAt        DateTime @default(now()) @map("created_at")

  paymentRequest PaymentRequest @relation(fields: [paymentRequestId], references: [id])
  processedBy    User           @relation("VendorPaymentProcessedBy", fields: [processedById], references: [id])

  @@map("vendor_payments")
}

// Goods Arrival Note — PM creates when goods physically arrive
enum GANStatus {
  CREATED   // PM created, waiting IM
  GRN_DONE  // IM verified and created GRN
}

model GoodsArrivalNote {
  id          String    @id @default(cuid())
  ganNumber   String    @unique @map("gan_number")  // GAN/26-27/001
  poId        String    @map("po_id")
  arrivalDate DateTime  @default(now()) @map("arrival_date")
  status      GANStatus @default(CREATED)
  notes       String?
  photoUrls   String[]  @default([]) @map("photo_urls")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  po        PurchaseOrder @relation(fields: [poId], references: [id])
  createdBy User          @relation("GANCreatedBy", fields: [createdById], references: [id])
  items     GANItem[]
  grn       GoodsReceipt?

  @@map("goods_arrival_notes")
}

model GANItem {
  id         String @id @default(cuid())
  ganId      String @map("gan_id")
  poItemId   String @map("po_item_id")
  materialId String @map("material_id")
  qtyArrived Float  @map("qty_arrived")

  gan      GoodsArrivalNote @relation(fields: [ganId], references: [id], onDelete: Cascade)
  poItem   POItem           @relation(fields: [poItemId], references: [id])
  material RawMaterial      @relation(fields: [materialId], references: [id])

  @@map("gan_items")
}

// Material Serials — individual barcodes generated at GRN or opening stock for every component
model MaterialSerial {
  id          String    @id @default(cuid())
  materialId  String    @map("material_id")
  grnId       String?   @map("grn_id")                 // null for opening stock serials
  stageType   String    @default("GN") @map("stage_type") // "PS" | "BB" | "GN" (general)
  barcode     String    @unique
  quantity    Int       @default(1)                    // units per pack (from material.packSize at GRN)
  status      String    @default("PRINTED")            // PRINTED | CONFIRMED | ALLOCATED | CONSUMED
  confirmedAt DateTime? @map("confirmed_at")
  allocatedToOrderId String? @map("allocated_to_order_id")
  allocatedToUnitId  String? @map("allocated_to_unit_id")
  jobCardItemId      String? @map("job_card_item_id")  // set when consumed via job card dispatch
  createdAt   DateTime  @default(now()) @map("created_at")

  material    RawMaterial    @relation(fields: [materialId], references: [id])
  grn         GoodsReceipt?  @relation(fields: [grnId], references: [id])
  jobCardItem JobCardItem?   @relation(fields: [jobCardItemId], references: [id])

  @@map("material_serials")
}

// Vendor Performance — recorded per PO after GRN
model VendorPerformance {
  id              String   @id @default(cuid())
  vendorId        String   @map("vendor_id")
  poId            String   @unique @map("po_id")
  deliveredOnTime Boolean  @map("delivered_on_time")
  qualityRating   Int      @map("quality_rating")   // 1-5
  pricingScore    Int      @map("pricing_score")    // 1-5 (was bid competitive vs others)
  notes           String?
  recordedById    String   @map("recorded_by_id")
  recordedAt      DateTime @default(now()) @map("recorded_at")

  vendor     Vendor        @relation(fields: [vendorId], references: [id])
  po         PurchaseOrder @relation(fields: [poId], references: [id])
  recordedBy User          @relation(fields: [recordedById], references: [id])

  @@map("vendor_performance")
}

// ─── Admin Notifications ────────────────────────────────────────────────────
model AdminNotification {
  id        String   @id @default(cuid())
  type      String   // PO_AUTO_ASSIGNED | PRICE_DEVIATION | OVERRIDE_REQUEST | LOW_STOCK
  title     String
  body      String
  data      Json?    // extra payload (e.g. poId, rfqId, materialId)
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_notifications")
}

// ─── PO Override Request ────────────────────────────────────────────────────
model POOverrideRequest {
  id           String   @id @default(cuid())
  rfqId        String   @map("rfq_id")
  requestedById String  @map("requested_by_id")
  reason       String
  aiWinnerId   String   @map("ai_winner_id")    // quote AI selected
  desiredId    String   @map("desired_id")       // quote PM wants
  status       String   @default("PENDING")      // PENDING | APPROVED | REJECTED
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime @default(now()) @map("created_at")

  requestedBy  User @relation(fields: [requestedById], references: [id])

  @@map("po_override_requests")
}

// ─── Damage Report ───────────────────────────────────────────────────────────
model DamageReport {
  id            String   @id @default(cuid())
  jobCardId     String?  @map("job_card_id")
  rawMaterialId String   @map("raw_material_id")
  batchId       String?  @map("batch_id")        // which GRN batch the damaged item came from
  stage         String?                           // e.g. CONTROLLER_ASSEMBLY
  qtyDamaged    Float    @map("qty_damaged")
  reason        String                            // broken_on_arrival | assembly_damage | wrong_spec | other
  notes         String?
  reportedById  String   @map("reported_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  jobCard     JobCard?       @relation(fields: [jobCardId], references: [id])
  rawMaterial RawMaterial    @relation(fields: [rawMaterialId], references: [id])
  batch       InventoryBatch? @relation("BatchDamages", fields: [batchId], references: [id])
  reportedBy  User           @relation(fields: [reportedById], references: [id])

  @@map("damage_reports")
}

// ─── Vendor Invoice & Payment Flow ──────────────────────────────────────────

model VendorInvoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique @map("invoice_number")
  poId          String   @map("po_id")
  vendorId      String   @map("vendor_id")
  amount        Float
  gstAmount     Float    @default(0) @map("gst_amount")
  tdsAmount     Float    @default(0) @map("tds_amount")
  netAmount     Float    @map("net_amount")
  fileUrl       String?  @map("file_url")
  notes         String?
  submittedAt   DateTime @default(now()) @map("submitted_at")
  status        String   @default("PENDING")

  po             PurchaseOrder   @relation(fields: [poId], references: [id])
  vendor         Vendor          @relation(fields: [vendorId], references: [id])
  paymentRequest PaymentRequest?

  @@map("vendor_invoices")
}

enum PaymentRequestStatus {
  SUBMITTED
  UNDER_REVIEW
  PENDING_APPROVAL
  APPROVED
  PROCESSING
  PAID
  REJECTED
}

model PaymentRequest {
  id              String               @id @default(cuid())
  requestNumber   String               @unique @map("request_number")
  poId            String               @unique @map("po_id")
  vendorInvoiceId String               @unique @map("vendor_invoice_id")
  requestedById   String               @map("requested_by_id")
  requestedAt     DateTime             @default(now()) @map("requested_at")
  status          PaymentRequestStatus @default(SUBMITTED)

  aiVerified         Boolean  @default(false) @map("ai_verified")
  aiVerificationNote String?  @map("ai_verification_note")

  accountsNote  String?   @map("accounts_note")
  accountsById  String?   @map("accounts_by_id")
  accountsAt    DateTime? @map("accounts_at")

  adminApprovedById String?   @map("admin_approved_by_id")
  adminApprovedAt   DateTime? @map("admin_approved_at")
  adminNote         String?   @map("admin_note")

  paymentAmount Float?    @map("payment_amount")
  paymentMode   String?   @map("payment_mode")
  paymentRef    String?   @map("payment_ref")
  paymentDate   DateTime? @map("payment_date")
  paymentById   String?   @map("payment_by_id")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  po              PurchaseOrder  @relation(fields: [poId], references: [id])
  vendorInvoice   VendorInvoice  @relation(fields: [vendorInvoiceId], references: [id])
  requestedBy     User           @relation("PaymentRequestedBy", fields: [requestedById], references: [id])
  accountsBy      User?          @relation("PaymentAccountsBy", fields: [accountsById], references: [id])
  adminApprovedBy User?          @relation("PaymentAdminApproved", fields: [adminApprovedById], references: [id])
  paymentBy       User?          @relation("PaymentProcessedBy", fields: [paymentById], references: [id])
  vendorPayments  VendorPayment[]

  @@map("payment_requests")
}

// ----- Samples -----
enum SampleStatus {
  PENDING
  APPROVED
  DISPATCHED
  RETURNED
  CLOSED
}

model SampleRequest {
  id           String       @id @default(cuid())
  sampleNumber String       @unique @map("sample_number")  // SAMP/26-27/001
  clientId     String       @map("client_id")
  productId    String?      @map("product_id")
  description  String?
  quantity     Int          @default(1)
  status       SampleStatus @default(PENDING)
  notes        String?
  requestedById  String     @map("requested_by_id")
  approvedById   String?    @map("approved_by_id")
  approvedAt     DateTime?  @map("approved_at")
  dispatchedAt   DateTime?  @map("dispatched_at")
  returnedAt     DateTime?  @map("returned_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  client      Client   @relation(fields: [clientId], references: [id])
  product     Product? @relation(fields: [productId], references: [id])
  requestedBy User     @relation("SampleRequestedBy", fields: [requestedById], references: [id])
  approvedBy  User?    @relation("SampleApprovedBy", fields: [approvedById], references: [id])

  @@map("sample_requests")
}

// ----- Implementation Goods -----
enum IGStatus {
  REQUESTED
  GAN_CREATED
  RECEIVED
  GAN_DONE
  GRN_DONE
  IN_USE
  IN_STORE
  RETURN_INITIATED
  PACKING
  PACKED
  DISPATCHED
  CLOSED
  REJECTED
  RETURNED
  RETAINED
}

model ImplementationGood {
  id              String   @id @default(cuid())
  igNumber        String   @unique @map("ig_number")  // IG/26-27/001
  clientId        String   @map("client_id")
  description     String
  items           String   @map("items")  // JSON: [{name, qty, unit, condition}]
  receivedDate    DateTime? @map("received_date")
  expectedArrival DateTime? @map("expected_arrival")
  expectedReturn  DateTime? @map("expected_return")
  returnedDate    DateTime? @map("returned_date")
  status          IGStatus  @default(RECEIVED)
  purpose         String?   // research purpose / notes
  notes           String?

  // GAN fields
  ganDate         DateTime? @map("gan_date")
  ganNotes        String?   @map("gan_notes")
  courierDetails  String?   @map("courier_details")
  ganById         String?   @map("gan_by_id")

  // GRN fields
  grnDate         DateTime? @map("grn_date")
  grnNotes        String?   @map("grn_notes")
  warehouseLocation String? @map("warehouse_location")
  grnById         String?   @map("grn_by_id")

  // Return / Dispatch fields
  returnInitiatedAt DateTime? @map("return_initiated_at")
  dnNumber        String?   @map("dn_number")
  boxCount        Int?      @map("box_count")
  dispatchedAt    DateTime? @map("dispatched_at")
  dispatchCourier String?   @map("dispatch_courier")
  trackingNumber  String?   @map("tracking_number")

  // Close / Reject
  closedAt        DateTime? @map("closed_at")
  rejectedAt      DateTime? @map("rejected_at")
  rejectionReason String?   @map("rejection_reason")

  createdById     String    @map("created_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  client    Client @relation(fields: [clientId], references: [id])
  createdBy User   @relation("IGCreatedBy", fields: [createdById], references: [id])
  ganBy     User?  @relation("IGGanBy", fields: [ganById], references: [id])
  grnBy     User?  @relation("IGGrnBy", fields: [grnById], references: [id])
  timeline  IGTimeline[]
  boxes     IGPackingBox[]

  @@map("implementation_goods")
}

model IGTimeline {
  id        String   @id @default(cuid())
  igId      String   @map("ig_id")
  status    String
  action    String
  notes     String?
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  ig   ImplementationGood @relation(fields: [igId], references: [id], onDelete: Cascade)
  user User               @relation("IGTimelineUser", fields: [userId], references: [id])

  @@map("ig_timeline")
}

model IGPackingBox {
  id        String   @id @default(cuid())
  igId      String   @map("ig_id")
  boxNumber Int      @map("box_number")
  label     String
  items     String?  // JSON string of items in this box
  photoUrl  String?  @map("photo_url")
  isSealed  Boolean  @default(false) @map("is_sealed")
  createdAt DateTime @default(now()) @map("created_at")

  ig ImplementationGood @relation(fields: [igId], references: [id], onDelete: Cascade)

  @@map("ig_packing_boxes")
}

// ----- Harness Production -----

enum HarnessUnitStatus {
  PENDING        // created when order converts, waiting acceptance
  ACCEPTED       // employee accepted the job
  CRIMPING       // crimping in progress
  QC_PENDING     // crimping done, waiting QC test
  QC_PASSED      // all connectors passed QC
  QC_FAILED      // one or more connectors failed
  READY          // QC passed, ready for dispatch / pairing
  DISPATCHED     // paired with controller and dispatched
}

model HarnessUnit {
  id             String            @id @default(cuid())
  serialNumber   String?           @unique @map("serial_number")
  barcode        String?           @unique
  orderId        String            @map("order_id")
  productId      String            @map("product_id")
  assignedUserId String?           @map("assigned_user_id")
  status         HarnessUnitStatus @default(PENDING)
  harnessModel   String?           @map("harness_model")  // e.g. "Ultra Bee", "Light Bee"
  qcData         Json?             @map("qc_data")   // per-connector pass/fail results
  remarks        String?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  order            Order            @relation(fields: [orderId], references: [id])
  product          Product          @relation(fields: [productId], references: [id])
  assignedUser     User?            @relation("HarnessAssignedTo", fields: [assignedUserId], references: [id])
  pairedController ControllerUnit?  @relation("PairedHarness") // back-ref from ControllerUnit.pairedHarness

  @@map("harness_units")
}

// Admin-configurable connectors per harness product (used as QC checklist)
model HarnessConnector {
  id          String  @id @default(cuid())
  productId   String  @map("product_id")
  name        String                          // e.g. "CAN", "USB", "Phase U", "Hall Sensor"
  description String?
  sortOrder   Int     @default(0) @map("sort_order")
  active      Boolean @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("harness_connectors")
}
